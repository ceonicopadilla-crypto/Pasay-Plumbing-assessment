{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "super_admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Report": {
      "title": "Report",
      "description": "Plumbing computation report",
      "type": "object",
      "properties": {
        "projectTitle": { "type": "string" },
        "bpNumber": { "type": "string" },
        "preparedBy": { "type": "string" },
        "completedDate": { "type": "string" },
        "googleDriveFileId": { "type": "string" },
        "googleDriveLink": { "type": "string" },
        "totalCost": { "type": "number" },
        "createdAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["projectTitle", "bpNumber", "userId"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "System activity log",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["action", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "#/entities/Report",
      "description": "Submitted reports"
    },
    "/auditLogs/{logId}": {
      "schema": "#/entities/AuditLog",
      "description": "System logs"
    }
  }
}
